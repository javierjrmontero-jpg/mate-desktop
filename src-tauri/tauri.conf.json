{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MATE",
  "version": "0.1.1",
  "identifier": "com.jjrm.mate",
  "build": {
    "devUrl": "https://mate.local",
    "frontendDist": "https://mate.local"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MATE — by JJRM",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "url": "https://mate.local"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Asistente personal estilo Jarvis sobre infraestructura propia",
    "longDescription": "MATE — Motor de Asistencia Técnica e Inteligencia. Asistente personal con chat, voz, calendario, email y tareas.",
    "copyright": "Copyright © 2026 JJRM",
    "category": "Utility",
    "publisher": "JJRM",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "languages": ["Spanish"]
      }
    }
  }
}