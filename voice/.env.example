# MATE — Configuración por dispositivo
# Copiá este archivo como .env y completá los valores para tu instalación.
# El archivo .env nunca se sube a git (está en .gitignore).

# ── Backend ───────────────────────────────────────────────────────────────────
# En red local (mismo router que la VM):
# MATE_URL=https://mate.local
# Desde cualquier red (DuckDNS):
MATE_URL=https://molmont.duckdns.org

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Necesario para: visión de pantalla ("describí la pantalla")
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Spotify (opcional) ────────────────────────────────────────────────────────
# Crear app en developer.spotify.com → Dashboard → Create App
# Redirect URI: http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
