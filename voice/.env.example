# MATE — Configuración por dispositivo
# Copiá este archivo como .env y completá los valores para tu instalación.
# El archivo .env nunca se sube a git (está en .gitignore).

# ── Backend ───────────────────────────────────────────────────────────────────
# En red local (mismo router que la VM):
# MATE_URL=https://mate.local
# Desde cualquier red (DuckDNS):
MATE_URL=https://molmont.duckdns.org

# ── Claude / Anthropic ────────────────────────────────────────────────────────
# Necesario para: visión de pantalla ("describí la pantalla")
ANTHROPIC_API_KEY=tu_clave_anthropic_aqui

# ── Spotify (opcional) ────────────────────────────────────────────────────────
# Crear app en developer.spotify.com → Dashboard → Create App
# Redirect URI: http://127.0.0.1:8888/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Telegram (PRO — opcional) ─────────────────────────────────────────────────
# 1. Crear bot con @BotFather en Telegram → /newbot → copiar el token
# 2. Escribirle al bot, luego ir a: https://api.telegram.org/bot<TOKEN>/getUpdates
#    y copiar el "id" del campo "chat"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── WhatsApp (PRO — opcional) ─────────────────────────────────────────────────
# Número por defecto para enviar mensajes (formato internacional sin + ni espacios)
# Ejemplo Argentina: 541161234567 (54 = código país, 11 = código área, número)
# Requiere WhatsApp Web abierto en Chrome en la PC
WHATSAPP_DEFAULT_NUMBER=

# ── Google Calendar (PRO — opcional) ─────────────────────────────────────────
# 1. Ir a https://console.cloud.google.com
# 2. Crear proyecto → Habilitar "Google Calendar API"
# 3. Credenciales → OAuth 2.0 Desktop → Descargar JSON → guardar en cualquier carpeta
# 4. Correr mate_calendar_auth.py UNA VEZ para autorizar
GOOGLE_CREDENTIALS_PATH=

# Zona horaria para eventos de calendario (default: America/Argentina/Buenos_Aires)
# MATE_TIMEZONE=America/Argentina/Buenos_Aires

# ── TLS / Seguridad ───────────────────────────────────────────────────────────
# Verificación TLS para la conexión al backend.
# - Dejar vacío o "true": usar CAs del sistema (recomendado para producción)
# - Ruta a un archivo .crt: cert pinning para servidores con certificado autofirmado
# - "false": deshabilitar verificación (solo para desarrollo local, INSEGURO en producción)
# MATE_TLS_VERIFY=true
# MATE_TLS_VERIFY=/ruta/a/mate_ca.crt
